<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.movementtracker.ui.OverlayView
        android:id="@+id/overlay_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:background="@color/panel_scrim"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/player_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/player_speed_placeholder"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ball_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/ball_speed_placeholder"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/peak_ball_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/peak_ball_speed_placeholder"
            android:textColor="@color/accent"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/drill_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/calibration_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/calibration_none"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/panel_scrim"
        android:paddingTop="4dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_session"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_session_start" />

            <Button
                android:id="@+id/btn_sessions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_sessions" />

            <Button
                android:id="@+id/btn_slowmo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_slowmo" />

            <Button
                android:id="@+id/btn_drill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_drill" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_calibrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_calibrate" />

            <Button
                android:id="@+id/btn_ar_calibrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_ar_calibrate" />

            <Button
                android:id="@+id/btn_reset_peak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_reset_peak" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
