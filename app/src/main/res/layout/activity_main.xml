<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.movementtracker.ui.OverlayView
        android:id="@+id/overlay_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:background="#99000000"
        android:padding="12dp">

        <TextView
            android:id="@+id/player_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/player_speed_placeholder"
            android:textColor="#00E5FF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ball_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ball_speed_placeholder"
            android:textColor="#FFD54F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/peak_ball_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/peak_ball_speed_placeholder"
            android:textColor="#FFAB40"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/calibration_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calibration_none"
            android:textColor="#B0BEC5"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_calibrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="@string/btn_calibrate" />

        <Button
            android:id="@+id/btn_reset_peak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_reset_peak" />
    </LinearLayout>
</FrameLayout>
