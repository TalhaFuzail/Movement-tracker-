<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Optional: confirms ball strikes by their impact sound during sessions. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.camera.any" />
    <uses-feature
        android:name="android.hardware.camera.ar"
        android:required="false" />

    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.MovementTracker"
        android:supportsRtl="true">

        <!-- configChanges: a rotation must not recreate the activity — that
             would silently discard a running session, drill and recording.
             CameraX and the overlay adapt to the new size on their own. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="fullSensor"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SessionsActivity"
            android:exported="false"
            android:label="@string/title_sessions" />

        <activity
            android:name=".ui.SessionDetailActivity"
            android:exported="false"
            android:label="@string/title_session_detail" />

        <activity
            android:name=".ui.ReplayActivity"
            android:exported="false"
            android:label="@string/title_replay" />

        <activity
            android:name=".ui.SlowMoActivity"
            android:exported="false"
            android:label="@string/title_slowmo" />

        <activity
            android:name=".ar.ArCalibrateActivity"
            android:exported="false"
            android:label="@string/title_ar_calibrate"
            android:screenOrientation="locked" />

        <meta-data
            android:name="com.google.ar.core"
            android:value="optional" />
    </application>
</manifest>
